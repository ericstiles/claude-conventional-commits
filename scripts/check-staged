#!/bin/bash
git diff --cached --quiet
if [[ $? -eq 0 ]]; then
    echo "No changes are currently staged for commit."
    git status --short
    printf "Would you like to add all changes? (y/N): "
    read -n 1 response
    echo
    if [[ "$response" == "y" || "$response" == "Y" ]]; then
        git add .
        echo "All changes have been staged."
        exit 0
    else
        echo "No files added to a commit. Exiting."
        exit 1
    fi
else
    echo "Changes are already staged for commit."
    exit 0
fi
