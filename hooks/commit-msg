#!/bin/bash
# Validates commit messages against conventional commit format.
# Valid types match those defined in ~/repo/pre-commit-scripts/scripts/cc

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

VALID_TYPES="build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test|tst"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# Ignore merge commits, fixup commits, and squash commits
if echo "$COMMIT_MSG" | grep -qE "^(Merge|Revert|fixup!|squash!)"; then
    exit 0
fi

# Pattern: <type>(<optional scope>)<!>: <description>
if ! echo "$COMMIT_MSG" | grep -qE "^($VALID_TYPES)(\([^)]+\))?(!)?: .+"; then
    echo ""
    echo -e "  ${RED}${BOLD}✗ Commit rejected — invalid conventional commit format${RESET}"
    echo ""
    echo -e "  ${DIM}Expected:${RESET}  ${BOLD}<type>(<optional scope>): <description>${RESET}"
    echo ""
    echo -e "  ${DIM}Examples:${RESET}  ${GREEN}feat(auth): add login page${RESET}"
    echo -e "             ${GREEN}fix: resolve null pointer on startup${RESET}"
    echo -e "             ${GREEN}chore!: drop support for Node 12${RESET}"
    echo ""
    echo -e "  ${DIM}Types:${RESET}     ${YELLOW}build  chore  ci  docs  feat  fix${RESET}"
    echo -e "             ${YELLOW}perf  refactor  revert  style  test${RESET}"
    echo ""
    echo -e "  ${DIM}Got:${RESET}       ${RED}$COMMIT_MSG${RESET}"
    echo ""
    exit 1
fi

echo ""
echo -e "  ${GREEN}${BOLD}✓ Conventional commit format validated${RESET}"
echo ""
exit 0
