#!/bin/bash
# Pre-commit hook: ensures files are staged before committing.
# Symlinked from ~/.githooks/pre-commit

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
RESET='\033[0m'

git diff --cached --quiet
if [[ $? -eq 0 ]]; then
    echo ""
    echo -e "  ${YELLOW}${BOLD}⚠ No changes are currently staged for commit.${RESET}"
    echo -e "  ${RED}Stage your files and re-run your commit command.${RESET}"
    echo ""
    exit 1
else
    echo ""
    echo -e "  ${GREEN}${BOLD}✓ Changes are staged and ready to commit.${RESET}"
    echo ""
    exit 0
fi
